# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Options (cost per 1M input/output tokens):
#   claude-sonnet-5   $3/$15  cheapest good option (intro $2/$10)
#   claude-opus-4-8   $5/$25  default — strong quality/cost balance
#   claude-fable-5    $10/$50 max capability
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_FALLBACK_MODEL=claude-opus-4-8
EFFORT=high
MAX_TOKENS=16000

# Voyage AI (embeddings)
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3.5
EMBEDDING_DIMENSION=1024

# Pinecone
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX=bullpen-concierge

# Retrieval
RETRIEVAL_TOP_K=6
RETRIEVAL_MIN_SCORE=0.30
